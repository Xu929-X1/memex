model Document {
  id               String            @id @default(cuid())
  userId           String
  documentTitle    String
  source           String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  sourceType       SourceType
  user             User              @relation(fields: [userId], references: [id])
  documentSections DocumentSection[]
  qualityRuns      ChunkQualityRun[]
}

model DocumentSection {
  id             Int                      @id @default(autoincrement())
  documentId     String
  sectionContent String
  sectionVector  Unsupported("vector")
  simVector      Unsupported("vector")?
  chunkIndex     Int
  kind           SectionKind              @default(TEXT)
  pageStart      Int?
  pageEnd        Int?
  updatedAt      DateTime                 @default(now()) @updatedAt
  searchVector   Unsupported("tsvector")? @default(dbgenerated("to_tsvector('simple'::regconfig, \"sectionContent\")"))
  document       Document                 @relation(fields: [documentId], references: [id])

  @@index([searchVector], map: "idx_document_section_search_vector", type: Gin)
  @@index([updatedAt], map: "idx_document_section_updated_at")
}

enum SourceType {
  PDF
  NOTION
  WEB
  MARKDOWN
  TEXT
}

enum SectionKind {
  TEXT
  TABLE
  FIGURE
}

model ChunkQualityRun {
  id                 String     @id @default(cuid())
  documentId         String
  createdAt          DateTime   @default(now())
  sourceType         SourceType
  totalChunks        Int
  textCount          Int
  tableCount         Int
  figureCount        Int
  meanChars          Int
  stddevChars        Int
  p5Chars            Int
  p95Chars           Int
  tinyRate           Float
  oversizedRate      Float
  midSentenceRate    Float
  whitespaceRate     Float
  boundarySimilarity Float?
  score              Float
  flags              Json
  metrics            Json

  document Document @relation(fields: [documentId], references: [id])

  @@index([documentId])
  @@index([createdAt])
}
