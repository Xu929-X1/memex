{
    "$schema": "../gen/schemas/desktop-schema.json",
    "identifier": "default",
    "description": "default permissions",
    "windows": [
        "main"
    ],
    "permissions": [
        "core:default",
        "shell:allow-open",
        {
            "identifier": "http:default",
            "allow": [
                { "url": "https://memex.up.railway.app/*" },
                { "url": "http://localhost:3000/*" }
            ]
        }
    ]
}