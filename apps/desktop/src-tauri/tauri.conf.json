{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "memex",
  "version": "0.1.0",
  "identifier": "com.memex.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "memex",
        "width": 420,
        "height": 720,
        "resizable": true,
        "decorations": true,
        "alwaysOnTop": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [],
    "resources": [
      "resources/*"
    ]
  }
}