{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": [
      "vite/client"
    ],
    "paths": {
      "@/*": ["./src/*"],
      "styled-system/*": ["./styled-system/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "styled-system/**/*.ts",
    "styled-system/**/*.tsx", "../memex/interceptors.ts",
  ],
  "exclude": [
    "src-tauri",
    "node_modules",
    "dist"
  ]
}