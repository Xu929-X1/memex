{
    "$schema": "https://schema.railpack.com",
    "steps": {
        "install": {
            "commands": [
                "npm ci"
            ]
        },
        "build": {
            "inputs": [
                {
                    "step": "install"
                }
            ],
            "commands": [
                "npm run build:web"
            ]
        }
    },
    "deploy": {
        "startCommand": "npm -w @memex/web start -- -p $PORT"
    }
}