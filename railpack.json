{
    "$schema": "https://schema.railpack.com",
    "steps": {
        "install": {
            "commands": [
                "npm install"
            ]
        },
        "build": {
            "inputs": [
                {
                    "step": "install"
                }
            ],
            "commands": [
                "npm run build:web"
            ]
        }
    },
    "deploy": {
        "startCommand": "cd apps/web && node_modules/.bin/next start"
    }
}